{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the B.O.M.B.S. store",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "shippingData": {
          "type": "object",
          "description": "The user's saved shipping information",
          "properties": {
            "fullName": {
              "type": "string",
              "description": "Full name for shipping"
            },
            "address": {
              "type": "string",
              "description": "Street address"
            },
            "city": {
              "type": "string",
              "description": "City"
            },
            "state": {
              "type": "string",
              "description": "State or province"
            },
            "zip": {
              "type": "string",
              "description": "ZIP or postal code"
            },
            "country": {
              "type": "string",
              "description": "Country"
            }
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and shipping data"
    }
  }
}
